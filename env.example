# ============================================
# IE3 - Ingeniería Especializada en Eficiencia Energética
# Variables de Entorno
# ============================================
# Copia este archivo a .env.local y completa con tus valores
# cp env.example .env.local

# ============================================
# MongoDB - Base de Datos
# ============================================
# Formato: mongodb://usuario:password@host:puerto/nombre-db
# Ejemplo local: mongodb://localhost:27017/ie3
# Ejemplo MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/ie3
MONGODB_URI=mongodb://localhost:27017/ie3

# ============================================
# NextAuth.js - Autenticación
# ============================================
# URL de tu aplicación (desarrollo o producción)
NEXTAUTH_URL=http://localhost:3000

# Secret para firmar tokens JWT
# Genera uno con: openssl rand -base64 32
# O usa cualquier string aleatorio y seguro
NEXTAUTH_SECRET=tu-secret-key-super-segura-aqui-cambiar-en-produccion

# ============================================
# Oracle Cloud Storage - Almacenamiento de Archivos
# ============================================
# Región de Oracle Cloud (ej: us-ashburn-1, us-phoenix-1, us-sanjose-1, eu-frankfurt-1)
# Extraída de tu URL: us-sanjose-1
ORACLE_REGION=us-sanjose-1

# Namespace de tu tenancy de Oracle Cloud
# Lo encuentras en: Oracle Cloud Console > Object Storage > Bucket Details
# Extraído de tu URL: axj9sziuwe9i
ORACLE_NAMESPACE=axj9sziuwe9i

# Nombre del bucket donde se guardarán los documentos
# Extraído de tu URL: IE3
ORACLE_BUCKET_NAME=IE3

# Access Key ID de Oracle Cloud
# Genera uno en: Oracle Cloud Console > Identity > Users > API Keys
# Es el "Fingerprint" o ID que Oracle te proporciona al crear la API Key
ORACLE_ACCESS_KEY_ID=tu-access-key-id-aqui

# Secret Access Key de Oracle Cloud
# Es el contenido completo del archivo .pem privado (incluyendo BEGIN/END)
# Se muestra solo una vez al crear la API Key - GUÁRDALO BIEN
ORACLE_SECRET_ACCESS_KEY=tu-secret-access-key-aqui

# Endpoint de Object Storage
# Construido automáticamente desde la región: https://objectstorage.{region}.oraclecloud.com
ORACLE_ENDPOINT=https://objectstorage.us-sanjose-1.oraclecloud.com

# ============================================
# Notas Importantes
# ============================================
# 1. NUNCA subas .env.local a git (ya está en .gitignore)
# 2. En producción, usa variables de entorno del servidor o un gestor de secretos
# 3. Para MongoDB Atlas, asegúrate de agregar tu IP a la whitelist
# 4. Para Oracle Cloud, necesitas tener un bucket creado previamente
